{
  "name": "sms-touch-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "start": "npm --workspace apps/api run start",
    "dev": "node scripts/dev.js",
    "dev:sh": "bash scripts/start-dev.sh",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:server": "npm run dev:api",
    "dev:worker": "npm --workspace apps/api run dev:worker",
    "dev:web": "npm --workspace apps/web run dev",
    "serve": "npm run build && npm run start",
    "build": "npm --workspace apps/web run build",
    "build:web": "npm --workspace apps/web run build",
    "typecheck": "npm --workspace apps/web run typecheck",
    "db:up": "docker compose -p sms-touch-platform up -d postgres",
    "db:migrate": "prisma db push",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "test:mock": "node scripts/test-mock.js"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  }
}
