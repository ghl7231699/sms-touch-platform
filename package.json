{
  "name": "sms-touch-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/src/app.js",
    "dev": "node scripts/dev.js",
    "dev:server": "node server/src/app.js",
    "dev:worker": "SMS_TASK_WORKER_ENABLED=true node server/src/app.js",
    "serve": "npm run build && node server/src/app.js",
    "build": "vite build --config web/vite.config.ts",
    "typecheck": "tsc -p web/tsconfig.json --noEmit",
    "dev:web": "vite --config web/vite.config.ts --host 127.0.0.1 --port 5173",
    "db:up": "docker compose -p sms-touch-platform up -d postgres",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "test:mock": "node scripts/test-mock.js"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "2.0.0",
    "@alicloud/openapi-client": "^0.4.14",
    "@alicloud/tea-util": "^1.4.10",
    "@prisma/client": "^6.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "typescript": "^5.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "prisma": "^6.1.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  }
}
